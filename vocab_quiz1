 {en:"wear", ch:"穿戴"}, {en:"bee", ch:"蜜蜂"}, {en:"see", ch:"看見"}, {en:"need", ch:"需要"}, {en:"seed", ch:"種子"}, {en:"week", ch:"星期"}, {en:"arm", ch:"手臂"}, {en:"art", ch:"藝術"}, {en:"car", ch:"汽車"}, {en:"card", ch:"卡片"}, {en:"far", ch:"遙遠的"}, {en:"or", ch:"或者"}, {en:"for", ch:"為了"}, {en:"fork", ch:"叉子"}, {en:"pork", ch:"豬肉"}, {en:"born", ch:"出生"}, {en:"her", ch:"她的/她(受格)"}, {en:"over", ch:"在...之上"}, {en:"river", ch:"河流"}, {en:"ruler", ch:"直尺"}, {en:"order", ch:"點菜/訂購"}, {en:"sir", ch:"先生/長官"}, {en:"bird", ch:"小鳥"}, {en:"girl", ch:"女孩"}, {en:"first", ch:"第一的"}, {en:"shirt", ch:"襯衫"}, {en:"fur", ch:"軟毛"}, {en:"burn", ch:"燃燒"}, {en:"turn", ch:"轉動"}, {en:"surf", ch:"衝浪"}, {en:"hurt", ch:"受傷"}, {en:"yes", ch:"是的"}, {en:"yet", ch:"尚未"}, {en:"yard", ch:"庭院"}, {en:"year", ch:"年"}, {en:"yo-yo", ch:"溜溜球"}, {en:"baby", ch:"嬰孩"}, {en:"body", ch:"身體"}, {en:"very", ch:"非常"}, {en:"many", ch:"許多"}, {en:"tidy", ch:"整齊乾淨的"}, {en:"by", ch:"旁邊"}, {en:"my", ch:"我的"}, {en:"shy", ch:"害羞的"}, {en:"dry", ch:"乾的"}, {en:"try", ch:"嘗試"}, {en:"ice", ch:"冰"}, {en:"nice", ch:"好的"}, {en:"face", ch:"臉"}, {en:"city", ch:"城市"}, {en:"circle", ch:"圓圈"}, {en:"pencil", ch:"鉛筆"}, {en:"cycle", ch:"循環"}, {en:"recycle", ch:"回收"}, {en:"age", ch:"年齡"}, {en:"cage", ch:"籠子"}, {en:"page", ch:"頁"}, {en:"giant", ch:"巨人"}, {en:"magic", ch:"有魔力的"}, {en:"gym", ch:"體育館"}, {en:"blow", ch:"吹"}, {en:"black", ch:"黑色的"}, {en:"block", ch:"街區"}, {en:"plan", ch:"計劃"}, {en:"play", ch:"遊戲/戲劇"}, {en:"place", ch:"地方"}, {en:"clap", ch:"拍手"}, {en:"class", ch:"班級"}, {en:"clean", ch:"清洗"}, {en:"glad", ch:"高興的"}, {en:"glue", ch:"膠水"}, {en:"glass", ch:"玻璃杯"}, {en:"fly", ch:"飛行"}, {en:"flag", ch:"旗子"}, {en:"flower", ch:"花"}, {en:"slim", ch:"纖細的"}, {en:"sleep", ch:"睡覺"}, {en:"bread", ch:"麵包"}, {en:"bring", ch:"帶來"}, {en:"brush", ch:"刷"}, {en:"pray", ch:"祈禱"}, {en:"price", ch:"價格"}, {en:"print", ch:"印刷"}, {en:"cry", ch:"哭"}, {en:"crab", ch:"螃蟹"}, {en:"crazy", ch:"瘋狂的"}, {en:"gram", ch:"公克"}, {en:"grade", ch:"年級/成績"}, {en:"grape", ch:"葡萄"}, {en:"drop", ch:"掉落"}, {en:"drum", ch:"鼓"}, {en:"fry", ch:"油炸"}, {en:"free", ch:"免費的"}, {en:"frog", ch:"青蛙"}, {en:"tree", ch:"樹"}, {en:"trip", ch:"旅程"}, {en:"scan", ch:"掃描"}, {en:"score", ch:"分數"}, {en:"school", ch:"學校"}, {en:"sky", ch:"天空"}, {en:"ski", ch:"滑雪"}, {en:"skate", ch:"冰鞋"}, {en:"small", ch:"小的"}, {en:"smart", ch:"聰明的"}, {en:"smile", ch:"微笑"}, {en:"snowy", ch:"下雪的"}, {en:"snack", ch:"點心"}, {en:"snake", ch:"蛇"}, {en:"swim", ch:"游泳"}, {en:"swing", ch:"鞦韆/擺動"}, {en:"sweet", ch:"甜的"}, {en:"spy", ch:"間諜"}, {en:"speak", ch:"說話"}, {en:"spell", ch:"拼寫"}, {en:"stay", ch:"停留"}, {en:"star", ch:"星星"}, {en:"start", ch:"開始"}, {en:"I", ch:"我"}, {en:"you", ch:"你/你們"}, {en:"we", ch:"我們"}, {en:"he", ch:"他"}, {en:"she", ch:"她"}, {en:"it", ch:"它"}, {en:"they", ch:"他們"}, {en:"my", ch:"我的"}, {en:"your", ch:"你的/你們的"}, {en:"his", ch:"他的"}, {en:"her", ch:"她的/她(受格)"}, {en:"its", ch:"它的"}, {en:"our", ch:"我們的"}, {en:"their", ch:"他們的"}, {en:"me", ch:"我(受格)"}, {en:"him", ch:"他(受格)"} 
    ];

    let quizList = [];
    let wrongRecords = []; // 儲存包含當時選項與學生選擇的記錄
    let currentIndex = 0;
    let score = 0;
    let unitScore = 0;
    let quizMode = 'en-to-ch';
    
    const SCRIPT_URL = "https://script.google.com/macros/s/AKfycbypyYTN7i8bb0-lHPRMQ7td9wQS8t9USz7pVTNzmKey0ob14BZD8cq1saumeKMGuuhB/exec"; 

    function initQuiz() {
        const name = document.getElementById('stu-name').value;
        if(!name) return alert("請輸入姓名");

        const count = parseInt(document.getElementById('quiz-count').value);
        quizMode = document.getElementById('quiz-mode').value;
        unitScore = 100 / count;
        quizList = [...wordBank].sort(() => 0.5 - Math.random()).slice(0, count);
        wrongRecords = [];
        currentIndex = 0;
        score = 0;
        
        document.getElementById('setup-page').classList.add('hidden');
        document.getElementById('result-page').classList.add('hidden');
        document.getElementById('quiz-page').classList.remove('hidden');
        
        renderQuestion();
    }

    function renderQuestion() {
        const q = quizList[currentIndex];
        document.getElementById('progress').innerText = `第 ${currentIndex + 1} 題 / 共 ${quizList.length} 題`;
        document.getElementById('question-display').innerText = (quizMode === 'en-to-ch') ? q.en : q.ch;

        const options = generateOptions(q);
        const area = document.getElementById('options-area');
        area.innerHTML = '';
        options.forEach(opt => {
            const btn = document.createElement('button');
            btn.className = 'option-item option-btn';
            btn.innerText = (quizMode === 'en-to-ch') ? opt.ch : opt.en;
            btn.onclick = () => handleAnswer(opt, q, options);
            area.appendChild(btn);
        });
    }

    function generateOptions(correctObj) {
        let opts = [correctObj];
        while(opts.length < 4) {
            let rand = wordBank[Math.floor(Math.random() * wordBank.length)];
            if(!opts.find(o => o.en === rand.en)) opts.push(rand);
        }
        return opts.sort(() => 0.5 - Math.random());
    }

    function handleAnswer(selectedOpt, correctObj, allOptions) {
        if(selectedOpt === correctObj) {
            score += unitScore;
        } else {
            // 記錄錯題：包含正確單字、學生選的單字、以及當時的所有選項
            wrongRecords.push({
                question: correctObj,
                studentChoice: selectedOpt,
                optionsSnapshot: allOptions
            });
        }
        currentIndex++;
        
        if(currentIndex < quizList.length) {
            renderQuestion();
        } else {
            showFinal();
        }
    }

    function showFinal() {
        document.getElementById('quiz-page').classList.add('hidden');
        document.getElementById('result-page').classList.remove('hidden');
        
        const finalScore = Math.round(score);
        document.getElementById('final-score').innerText = finalScore;
        
        const cls = document.getElementById('stu-class').value;
        const no = document.getElementById('stu-no').value;
        const name = document.getElementById('stu-name').value;
        document.getElementById('result-info').innerText = `${cls} ${no} 號 ${name}`;

        // 顯示複習區域
        const container = document.getElementById('review-container');
        container.innerHTML = '';
        if(wrongRecords.length > 0) {
            const title = document.createElement('h3');
            title.innerText = "❌ 錯題回顧與訂正";
            title.style.color = "#d9534f";
            title.style.marginTop = "30px";
            container.appendChild(title);

            wrongRecords.forEach((record, idx) => {
                const card = document.createElement('div');
                card.className = 'review-card';
                
                const qTitle = document.createElement('div');
                qTitle.className = 'review-question-title';
                qTitle.innerText = `題目 ${idx + 1}：${(quizMode === 'en-to-ch') ? record.question.en : record.question.ch}`;
                card.appendChild(qTitle);

                const grid = document.createElement('div');
                grid.className = 'options-grid';

                record.optionsSnapshot.forEach(opt => {
                    const item = document.createElement('div');
                    item.className = 'option-item';
                    item.innerText = (quizMode === 'en-to-ch') ? opt.ch : opt.en;

                    // 標色邏輯
                    if (opt === record.question) {
                        item.classList.add('is-correct'); // 正確答案綠底
                    } else if (opt === record.studentChoice) {
                        item.classList.add('is-wrong'); // 學生選錯的紅底
                    }
                    
                    grid.appendChild(item);
                });

                card.appendChild(grid);
                container.appendChild(card);
            });
        } else {
            container.innerHTML = "<h3 style='color:green; text-align:center;'>太強了！全部答對！🌟</h3>";
        }

        uploadScore(cls, no, name, finalScore);
    }

    function uploadScore(cls, no, name, scoreVal) {
        const qCount = document.getElementById('quiz-count').value;
        document.getElementById('saving-loader').innerText = "正在儲存成績至雲端...";
        fetch(SCRIPT_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                cls: cls, no: no, name: name, count: qCount,
                mode: (quizMode === 'en-to-ch' ? "英翻中" : "中翻英"),
                score: scoreVal
            })
        }).then(() => {
            document.getElementById('saving-loader').innerText = "✅ 成績已成功上傳";
            document.getElementById('saving-loader').style.color = "green";
        }).catch(() => {
            document.getElementById('saving-loader').innerText = "❌ 上傳失敗";
            document.getElementById('saving-loader').style.color = "red";
        });
    }
</script>

